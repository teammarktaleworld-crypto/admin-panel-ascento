  "tests": [
    {
      "name": "Create Student",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/admin/students",
        "headers": {
          "Content-Type": "application/json",
          "x-session-key": "{{sessionKey}}"
        },
        "body": {
          "fullName": "Test Student {{suffix}}",
          "parentName": "Test Parent",
          "parentPhone": "9999999999",
          "parentEmail": "test.student.{{suffix}}@school.com",
          "domainId": "{{domainId}}",
          "gender": "male",
          "dateOfBirth": "2012-01-01",
          "address": "123 Test Lane",
          "city": "Test City",
          "state": "Test State",
          "bloodGroup": "O+"
        }
      },
      "test": "pm.test('Student created', function () { pm.response.to.have.status(201); });\nconst json = pm.response.json();\npm.collectionVariables.set('studentId', json.data.student.id);\npm.collectionVariables.set('studentLoginEmail', json.data.student.parentEmail);\npm.collectionVariables.set('studentLoginPassword', json.data.temporaryPassword);"
    },
    {
      "name": "Student Login",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/login",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "{{studentLoginEmail}}",
          "password": "{{studentLoginPassword}}",
          "role": "student"
        }
      },
      "test": "pm.test('Student login success', function () { pm.response.to.have.status(200); });\nconst json = pm.response.json();\npm.collectionVariables.set('studentSessionKey', json.data.sessionKey);"
    }
  ],
